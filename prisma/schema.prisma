// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum CartStatus {
  ACTIVE
  ORDERED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

// User
model User {
  id          String    @id @default(cuid())
  email       String    @unique
  password    String
  role        Role      @default(USER)
  firstName   String?
  lastName    String?
  phone       String?
  isVerified  Boolean   @default(true)

  addresses   Address[]
  cart        Cart?
  orders      Order[]

  created_at  DateTime  @default(now()) @db.Timestamptz(3)
  updated_at  DateTime  @updatedAt @db.Timestamptz(3)

  @@map("users")
}

// Product
model Product {
  id          String   @id @default(cuid())
  name        String
  price       Decimal  @db.Decimal(12, 2)
  description String?
  sku         String   @unique
  stock       Int      @default(0)
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id])
  images      String[] // array of image URLs
  isActive    Boolean  @default(true)
  tags        String[]

  cartItems   CartItem[]
  orderItems  OrderItem[]

  created_at  DateTime @default(now()) @db.Timestamptz(3)
  updated_at  DateTime @updatedAt @db.Timestamptz(3)

  @@map("products")
}

// Category (self-referencing for nested categories)
model Category {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  parentId  String?
  parent    Category? @relation("CategoryTree", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryTree")
  products  Product[]

  @@map("categories")
}

// Address
model Address {
  id           String  @id @default(cuid())
  userId       String
  user         User    @relation(fields: [userId], references: [id])
  fullName     String
  phone        String
  addressLine  String
  city         String
  state        String?
  postalCode   String?
  country      String?
  isDefault    Boolean @default(false)

  // Used as shipping address in orders
  orders       Order[]

  created_at   DateTime @default(now()) @db.Timestamptz(3)
  updated_at   DateTime @updatedAt @db.Timestamptz(3)

  @@map("addresses")
}

// Cart
model Cart {
  id        String      @id @default(cuid())
  userId    String      @unique
  user      User        @relation(fields: [userId], references: [id])
  status    CartStatus  @default(ACTIVE)
  items     CartItem[]

  created_at DateTime @default(now()) @db.Timestamptz(3)
  updated_at DateTime @updatedAt @db.Timestamptz(3)

  @@map("carts")
}

// Cart Item
model CartItem {
  id         String   @id @default(cuid())
  cartId     String
  cart       Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId  String
  product    Product  @relation(fields: [productId], references: [id])
  quantity   Int
  price      Decimal  @db.Decimal(12, 2) // price at the time of adding to cart

  @@unique([cartId, productId])
  @@map("cart_items")
}

// Order
model Order {
  id                String        @id @default(cuid())
  userId            String
  user              User          @relation(fields: [userId], references: [id])
  totalAmount       Decimal       @db.Decimal(12, 2)
  paymentStatus     PaymentStatus @default(PENDING)
  orderStatus       OrderStatus   @default(PENDING)
  shippingAddressId String
  shippingAddress   Address       @relation(fields: [shippingAddressId], references: [id])

  items             OrderItem[]

  created_at        DateTime @default(now()) @db.Timestamptz(3)
  updated_at        DateTime @updatedAt @db.Timestamptz(3)

  @@map("orders")
}

// Order Item
model OrderItem {
  id         String   @id @default(cuid())
  orderId    String
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId  String
  product    Product  @relation(fields: [productId], references: [id])
  quantity   Int
  price      Decimal  @db.Decimal(12, 2) // price at the time of order

  @@unique([orderId, productId])
  @@map("order_items")
}